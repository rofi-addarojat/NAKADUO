rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidProductCreate(data) {
      return data.keys().hasAll(['name', 'price', 'imageUrl', 'countryOfOrigin', 'fit', 'stock', 'createdAt', 'updatedAt'])
        && (data.keys().size() >= 8 && data.keys().size() <= 10)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.countryOfOrigin is string && data.countryOfOrigin.size() <= 100
        && data.fit is string && data.fit.size() <= 50
        && data.stock is number
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (!('whatsAppLink' in data) || (data.whatsAppLink is string && data.whatsAppLink.size() <= 2000))
        && (!('marketplaceLink' in data) || (data.marketplaceLink is string && data.marketplaceLink.size() <= 2000));
    }

    function isValidProductUpdate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.countryOfOrigin is string && data.countryOfOrigin.size() <= 100
        && data.fit is string && data.fit.size() <= 50
        && data.stock is number
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time
        && (!('whatsAppLink' in data) || (data.whatsAppLink is string && data.whatsAppLink.size() <= 2000))
        && (!('marketplaceLink' in data) || (data.marketplaceLink is string && data.marketplaceLink.size() <= 2000));
    }

    function isValidArticleCreate(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'excerpt', 'imageUrl', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200 && data.slug.matches('^[a-z0-9\\-]+$')
        && data.content is string && data.content.size() <= 50000
        && data.excerpt is string && data.excerpt.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }
    
    function isValidArticleUpdate(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200 && data.slug.matches('^[a-z0-9\\-]+$')
        && data.content is string && data.content.size() <= 50000
        && data.excerpt is string && data.excerpt.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time;
    }

    // Admins
    match /admins/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Only readable by admins or owner.
      allow read: if isSignedIn() && isAdmin();
      allow write: if false; 
    }

    // Products
    match /products/{productId} {
      // Products are publicly readable for storefront
      allow get: if isValidId(productId) && true;
      allow list: if true; 
      
      allow create: if isAdmin() && isValidId(productId) && isValidProductCreate(incoming());
      
      allow update: if isAdmin() && isValidId(productId) && isValidProductUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'imageUrl', 'countryOfOrigin', 'fit', 'stock', 'whatsAppLink', 'marketplaceLink', 'updatedAt'])
      );
      
      allow delete: if isAdmin() && isValidId(productId);
    }
    
    // Articles
    match /articles/{articleId} {
      allow get: if isValidId(articleId) && true;
      allow list: if true;
      
      allow create: if isAdmin() && isValidId(articleId) && isValidArticleCreate(incoming());
      
      allow update: if isAdmin() && isValidId(articleId) && isValidArticleUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'slug', 'content', 'excerpt', 'imageUrl', 'updatedAt'])
      );
      
      allow delete: if isAdmin() && isValidId(articleId);
    }
    
    // siteContent
    match /siteContent/{docId} {
      allow get: if isValidId(docId) && true;
      allow list: if true;
      allow create: if isAdmin() && docId == 'landingPage'
        && incoming().keys().hasAll(['headline', 'description', 'tagline', 'updatedAt'])
        && incoming().keys().size() == 4
        && incoming().headline is string && incoming().headline.size() <= 500
        && incoming().description is string && incoming().description.size() <= 2000
        && incoming().tagline is string && incoming().tagline.size() <= 500
        && incoming().updatedAt == request.time;
      allow update: if isAdmin() && docId == 'landingPage'
        && incoming().headline is string && incoming().headline.size() <= 500
        && incoming().description is string && incoming().description.size() <= 2000
        && incoming().tagline is string && incoming().tagline.size() <= 500
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['headline', 'description', 'tagline', 'updatedAt']);
      allow delete: if false; // Don't delete landing page
    }
    
    // settings
    match /settings/{docId} {
       allow get: if isValidId(docId) && true;
       allow list: if true;
       allow create: if isAdmin() && docId == 'general'
         && incoming().keys().hasAll(['faviconUrl', 'logoUrl', 'waAdmin', 'updatedAt'])
         && incoming().keys().size() == 4
         && incoming().faviconUrl is string && incoming().faviconUrl.size() <= 2000
         && incoming().logoUrl is string && incoming().logoUrl.size() <= 2000
         && incoming().waAdmin is string && incoming().waAdmin.size() <= 50
         && incoming().updatedAt == request.time;
       allow update: if isAdmin() && docId == 'general'
         && incoming().faviconUrl is string && incoming().faviconUrl.size() <= 2000
         && incoming().logoUrl is string && incoming().logoUrl.size() <= 2000
         && incoming().waAdmin is string && incoming().waAdmin.size() <= 50
         && incoming().updatedAt == request.time
         && incoming().diff(existing()).affectedKeys().hasOnly(['faviconUrl', 'logoUrl', 'waAdmin', 'updatedAt']);
       allow delete: if false;
    }
  }
}
